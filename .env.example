# 环境变量配置
# 复制此文件为 .env 并填入真实值

# LLM 配置（可选 minimax / openai）
LLM_PROVIDER=minimax

# MiniMax API（必填）
MINIMAX_API_KEY=sk-api-BKOwp0TAbkYz6n1fzrGYDSllBe8muFhq-f8pcQNeqmyE88gyXAY1Ih3MGmKEKvOUEg-SdbFJ5HFWScNWPPaOktB_513t3s4Msp-GzIx_wRQTgmChfIH8asY
MINIMAX_MODEL=MiniMax-M2.5

# OpenAI API（备用）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Embedding 配置
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# RAG 配置
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5
SIMILARITY_THRESHOLD=0.5

# 向量存储类型：chroma / elasticsearch
VECTORSTORE_TYPE=chroma

# Elasticsearch 配置
ES_HOST=http://localhost:9200
ES_INDEX=travel_guide
ES_USER=elastic
ES_PASSWORD=your_password_here