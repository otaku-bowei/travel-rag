# 环境变量配置
# 复制此文件为 .env 并填入真实值

# LLM 配置（可选 minimax / openai）
LLM_PROVIDER=minimax

# MiniMax API（必填）
MINIMAX_API_KEY=sk-cp-lbmPytkp20eG-aDxU-HB1qY3vTbBQcCdXPRrCkd3LIpVN95qfReasgdC72TrHfHQOFLBeEX_h2BXhhmGszCTkPHRgIWTcwz51Ydv6tK4Dc-NFmnackvtaoc
MINIMAX_MODEL=MiniMax-M2.5

# OpenAI API（备用）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Embedding 配置
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu
HF_ENDPOINT=https://hf-mirror.com

# LangChain Serve 配置（可选）
LANGCHAIN_HOST=http://localhost:8000
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=http://localhost:1984
LANGCHAIN_PROJECT=travel-rag

# RAG 配置
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5
SIMILARITY_THRESHOLD=0.5

# 向量存储类型：chroma / elasticsearch
VECTORSTORE_TYPE=chroma

# Elasticsearch 配置
ES_HOST=http://localhost:9200
ES_INDEX=travel_guide
ES_USER=elastic
ES_PASSWORD=your_password_here